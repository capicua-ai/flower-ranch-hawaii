// Prisma schema file — https://pris.ly/d/prisma-schema
//
// Getting started:
//   1. Set DATABASE_URL in .env.local (never commit it)
//   2. Define your models below
//   3. Run: pnpm prisma migrate dev --name init
//
// Notes for Prisma 7:
//   - The datasource URL lives in prisma.config.ts (not here)
//   - The PrismaClient is instantiated with an adapter in src/lib/db.ts
//   - The generated client lives in src/generated/prisma — always import via @/lib/db
//
// The singleton is in src/lib/db.ts. Always import `db` from there.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Define your models below this line.

// ── Auth ─────────────────────────────────────────────────────────────────────

/// Local mirror of a Souped-authenticated user, lazy-synced from the JWT.
model User {
  id         String   @id @default(cuid())
  soupedId   String   @unique // the `sub` claim from the Souped JWT
  email      String   @unique
  roles      String[] // mirrors the JWT `roles` claim
  lastSyncAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

// ── Storefront content (editable via Souped Chalk) ───────────────────────────

/// Global site copy. Singleton — exactly one row (id = "singleton").
model SiteSettings {
  id           String   @id @default("singleton")
  heroBadge    String
  heroTitle    String
  heroSubtitle String
  contactEmail String
  updatedAt    DateTime @updatedAt

  @@map("site_settings")
}

/// Products in the storefront catalog.
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String
  price       String
  priceNote   String
  image       String
  description String
  inStock     Boolean  @default(true)
  order       Int      @default(0)
  specs       Json // [{ label, value }] — rendered, not Chalk-edited in v1
  gallery     Json // string[] of image URLs — rendered, not Chalk-edited in v1
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

/// Blog articles.
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  image       String
  date        String
  readingTime String
  body        String // paragraphs separated by blank lines
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

/// Health-benefit cards on the home page. Fixed count by design.
model Benefit {
  id    String @id @default(cuid())
  title String
  body  String
  icon  String // lucide icon name
  order Int    @default(0)

  @@map("benefits")
}

/// "Delivered fresh" journey steps. Fixed count by design.
model DeliveryStep {
  id    String @id @default(cuid())
  title String
  body  String
  icon  String // lucide icon name
  order Int    @default(0)

  @@map("delivery_steps")
}
